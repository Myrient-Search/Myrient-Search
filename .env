APPLICATION_NAME=Minerva Search

# IGDB
TWITCH_CLIENT_ID =
TWITCH_CLIENT_SECRET =

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=minerva
POSTGRES_USER=minerva
POSTGRES_PASSWORD=minerva_secret

# Meilisearch
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=minerva_meili_key

# Admin panel
ADMIN_KEY=change_me_please

# AI Chat
AI_ENABLED=false
AI_API_KEY=
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
AI_MODEL=gemini-2.5-flash
BASE_URL=http://localhost:5173

# Minerva archive
MINERVA_HOST=https://minerva-archive.org
MINERVA_CACHE_DIR=/data/minerva-cache

# Torrent backend
TORRENT_IDLE_MS=10000
TORRENT_WARM_POOL_MAX=10
TORRENT_MEMORY_CAP_MB=256
TORRENT_MAX_CONNS=150